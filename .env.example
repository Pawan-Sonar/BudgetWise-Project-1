# BudgetWise — Environment template
# Copy to `.env` and adjust for your environment (`cp .env.example .env`).
# Docker Compose, the FastAPI backend, and the React build will all pick these up.

# ─── Mongo ───
MONGO_URL=mongodb://mongodb:27017
DB_NAME=budgetwise_db

# ─── Auth ───
# Generate a strong value for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_in_production_to_a_secure_random_string

# ─── CORS ───
# Use "*" for local dev. For production, set a comma-separated whitelist
# (e.g. CORS_ORIGINS=https://app.example.com,https://staging.example.com).
CORS_ORIGINS=*

# ─── App URLs ───
# Where the React frontend is served (used in password-reset emails).
FRONTEND_URL=http://localhost:3000
# Backend URL that the React app should call.
REACT_APP_BACKEND_URL=http://localhost:8001

# ─── Environment flag ───
# `development` exposes the dev_reset_link in /auth/forgot-password responses
# so the portfolio demo works without a real inbox. Set to `production` to disable.
ENVIRONMENT=development

# ─── Google OAuth (optional) ───
# Leave blank if you don't want the "Continue with Google" button to work locally.
# Obtain at https://console.cloud.google.com/apis/credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
