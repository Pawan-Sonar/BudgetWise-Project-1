# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# --- Editors / IDEs ---
.idea/
.vscode/
*.swp

# --- OS ---
.DS_Store
Thumbs.db

# --- Dependencies ---
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
.yarn/cache
.yarn/build-state.yml

# --- Production builds ---
build/
dist/
*.tsbuildinfo

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# --- Environment files (never commit secrets) ---
.env
.env.*
!.env.example
backend/.env
frontend/.env
*.pem
*.key
credentials.json
*token.json*

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Coverage / test artifacts ---
/coverage
test_reports/

# --- Build caches ---
.cache/
**/.cache/

# --- Deployment ---
.vercel/

# --- Archives & binaries ---
*.zip
*.tar
*.tar.gz
*.tgz
*.pack
*.deb
*.dylib

# --- Database dumps ---
dump.rdb
